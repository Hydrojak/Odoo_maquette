<odoo>
    <record id="view_sav_magasin_part_line_form_stock_flow" model="ir.ui.view">
        <field name="name">sav.magasin.part.line.form.stock.flow</field>
        <field name="model">sav.magasin.part.line</field>
        <field name="inherit_id" ref="sav_magasin_stock.view_sav_magasin_part_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_check_stock']" position="after">
                <button name="action_open_stock_pickings" type="object" string="Flux stock" invisible="stock_picking_count == 0"/>
                <button name="action_refresh_stock_flow_status" type="object" string="Synchroniser stock" invisible="stock_picking_count == 0"/>
            </xpath>
            <xpath expr="//group[@name='stock_decision_group']" position="after">
                <group string="Flux stock Odoo" name="stock_flow_group">
                    <field name="stock_picking_count" readonly="1"/>
                    <field name="stock_flow_state_note" readonly="1" invisible="not stock_flow_state_note"/>
                    <field name="stock_reservation_picking_id" readonly="1"/>
                    <field name="stock_transfer_picking_id" readonly="1"/>
                    <field name="stock_consumption_picking_id" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_sav_magasin_part_line_list_stock_flow" model="ir.ui.view">
        <field name="name">sav.magasin.part.line.list.stock.flow</field>
        <field name="model">sav.magasin.part.line</field>
        <field name="inherit_id" ref="sav_magasin_stock.view_sav_magasin_part_line_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='stock_decision_note']" position="after">
                <field name="stock_picking_count" readonly="1"/>
                <field name="stock_flow_state_note" readonly="1"/>
            </xpath>
            <xpath expr="//button[@name='action_mark_reserved']" position="after">
                <button name="action_open_stock_pickings" type="object" string="Flux" invisible="stock_picking_count == 0"/>
                <button name="action_refresh_stock_flow_status" type="object" string="Sync" invisible="stock_picking_count == 0"/>
            </xpath>
        </field>
    </record>

    <record id="view_sav_magasin_quick_receipt_form_stock_flow" model="ir.ui.view">
        <field name="name">sav.magasin.quick.receipt.form.stock.flow</field>
        <field name="model">sav.magasin.quick.receipt</field>
        <field name="inherit_id" ref="sav_magasin_purchase.view_sav_magasin_quick_receipt_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_stock_picking" type="object" string="Réception stock" invisible="not stock_picking_id"/>
            </xpath>
            <xpath expr="//field[@name='received_part_line_count']" position="after">
                <field name="stock_picking_id" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='line_ids']/list/field[@name='purchase_order_id']" position="after">
                <field name="stock_move_id" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_picking_form_sav_magasin_flow" model="ir.ui.view">
        <field name="name">stock.picking.form.sav.magasin.flow</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Re-Watt ERP" invisible="not sav_order_id and not sav_part_line_id and not sav_quick_receipt_id">
                    <field name="sav_order_id" readonly="1"/>
                    <field name="sav_part_line_id" readonly="1"/>
                    <field name="sav_quick_receipt_id" readonly="1"/>
                    <button name="action_open_sav_order" type="object" string="Ouvrir dossier batterie" invisible="not sav_order_id and not sav_part_line_id and not sav_quick_receipt_id"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_sav_magasin_stock_pickings" model="ir.actions.act_window">
        <field name="name">Flux stock batterie</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="domain">['|', ('sav_order_id', '!=', False), '|', ('sav_part_line_id', '!=', False), ('sav_quick_receipt_id', '!=', False)]</field>
    </record>

    <menuitem id="menu_sav_magasin_stock_pickings" name="Flux stock batterie" parent="sav_magasin_stock.menu_sav_magasin_stock" action="action_sav_magasin_stock_pickings" sequence="40"/>
</odoo>

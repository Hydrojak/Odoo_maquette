<odoo>
    <record id="view_sav_magasin_sav_order_search" model="ir.ui.view">
        <field name="name">sav.magasin.order.search</field>
        <field name="model">sav.magasin.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="device_name"/>
                <field name="serial_number"/>
                <filter string="Mes dossiers" name="my_orders" domain="[('user_id', '=', uid)]"/>
                <filter string="Ouverts" name="open" domain="[('state', 'not in', ['closed', 'cancelled'])]"/>
                <filter string="Diagnostic" name="diagnosis" domain="[('state', '=', 'diagnosis')]"/>
                <filter string="Attente client" name="customer_wait" domain="[('state', '=', 'customer_wait')]"/>
                <filter string="Attente pièce" name="part_wait" domain="[('state', '=', 'part_wait')]"/>
                <filter string="À restituer" name="ready" domain="[('state', '=', 'ready')]"/>
                <filter string="Clôturés" name="closed" domain="[('state', '=', 'closed')]"/>
                <separator string="Grouper par"/>
                <filter string="Statut" name="group_state" context="{'group_by': 'state'}"/>
                <filter string="Magasin" name="group_warehouse" context="{'group_by': 'warehouse_id'}"/>
                <filter string="Technicien" name="group_technician" context="{'group_by': 'technician_id'}"/>
                <filter string="Client" name="group_partner" context="{'group_by': 'partner_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_sav_magasin_sav_order_list" model="ir.ui.view">
        <field name="name">sav.magasin.order.list</field>
        <field name="model">sav.magasin.order</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'cancelled'" decoration-warning="state in ['customer_wait', 'part_wait']" decoration-success="state in ['returned', 'closed']">
                <field name="name"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="device_name"/>
                <field name="warehouse_id"/>
                <field name="technician_id"/>
                <field name="deposit_date"/>
                <field name="promised_date"/>
                <field name="amount_total"/>
            </list>
        </field>
    </record>

    <record id="view_sav_magasin_sav_order_kanban" model="ir.ui.view">
        <field name="name">sav.magasin.order.kanban</field>
        <field name="model">sav.magasin.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="device_name"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="amount_total"/>
                <field name="kanban_color"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click o_kanban_color_#{record.kanban_color.raw_value}">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                            </div>
                            <div><field name="partner_id"/></div>
                            <div><field name="device_name"/></div>
                            <div>Priorité : <field name="priority"/></div>
                            <div>Total estimé : <field name="amount_total"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_sav_magasin_sav_order_form" model="ir.ui.view">
        <field name="name">sav.magasin.order.form</field>
        <field name="model">sav.magasin.order</field>
        <field name="arch" type="xml">
            <form string="Dossier SAV">
                <header>
                    <button name="action_validate_deposit" type="object" string="Valider dépôt" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_start_diagnosis" type="object" string="Lancer diagnostic" class="btn-primary" invisible="state not in ['new']"/>
                    <button name="action_wait_customer" type="object" string="Attente client" invisible="state not in ['diagnosis', 'repair']"/>
                    <button name="action_wait_part" type="object" string="Attente pièce" invisible="state not in ['diagnosis', 'repair']"/>
                    <button name="action_start_repair" type="object" string="Réparer" class="btn-primary" invisible="state not in ['diagnosis', 'customer_wait', 'part_wait']"/>
                    <button name="action_ready" type="object" string="Prêt à restituer" class="btn-primary" invisible="state != 'repair'"/>
                    <button name="action_mark_invoiced" type="object" string="Marquer facturé" invisible="state != 'ready'"/>
                    <button name="action_returned" type="object" string="Restituer" class="btn-primary" invisible="state not in ['ready', 'invoiced']"/>
                    <button name="action_close" type="object" string="Clôturer" invisible="state != 'returned'"/>
                    <button name="action_cancel" type="object" string="Annuler" invisible="state in ['closed', 'cancelled']"/>
                    <button name="action_reset_to_draft" type="object" string="Remettre en brouillon" invisible="state != 'cancelled'"/>
                    <button name="action_print_deposit" type="object" string="Bon de dépôt"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,new,diagnosis,part_wait,repair,ready,invoiced,returned,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_customer" type="object" class="oe_stat_button" icon="fa-user" invisible="not partner_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Client</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <field name="contact_warning" readonly="1" invisible="not contact_warning" class="text-danger"/>
                    <group>
                        <group string="Client">
                            <field name="partner_id" context="{'default_customer_rank': 1}"/>
                            <field name="billing_partner_id"/>
                            <field name="delivered_partner_id"/>
                            <field name="warehouse_id"/>
                        </group>
                        <group string="Pilotage">
                            <field name="user_id"/>
                            <field name="technician_id"/>
                            <field name="priority"/>
                            <field name="deposit_date"/>
                            <field name="promised_date"/>
                            <field name="return_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Résumé dépôt">
                            <group>
                                <group string="Produit déposé">
                                    <field name="device_name"/>
                                    <field name="brand_id"/>
                                    <field name="range_id"/>
                                    <field name="model_id"/>
                                    <field name="serial_number"/>
                                    <field name="warranty_state"/>
                                </group>
                                <group string="Déclaration client">
                                    <field name="symptom" placeholder="Problème déclaré par le client..."/>
                                    <field name="accessories" placeholder="Chargeur, câble, batterie, sacoche..."/>
                                    <field name="visual_state" placeholder="Bon état, rayures, casse, pièce manquante..."/>
                                </group>
                            </group>
                        </page>
                        <page string="Diagnostic">
                            <field name="diagnosis" placeholder="Diagnostic technique, constat, tests réalisés..."/>
                            <field name="repair_note" placeholder="Compte-rendu d'intervention..."/>
                            <field name="customer_note" placeholder="Information transmise au client..."/>
                        </page>
                        <page string="Pièces / stock">
                            <field name="part_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="note"/>
                                </list>
                            </field>
                            <group>
                                <field name="amount_parts" readonly="1"/>
                                <field name="amount_labor"/>
                                <field name="amount_total" readonly="1"/>
                            </group>
                        </page>
                        <page string="Commercial">
                            <group>
                                <field name="sale_order_id"/>
                                <field name="invoice_id"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_sav_magasin_sav_order" model="ir.actions.act_window">
        <field name="name">Dossiers SAV</field>
        <field name="res_model">sav.magasin.order</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_open': 1}</field>
    </record>
</odoo>

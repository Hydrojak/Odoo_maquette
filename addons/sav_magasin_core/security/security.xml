<odoo>
    <record id="module_category_sav_magasin" model="ir.module.category">
        <field name="name">Re-Watt ERP</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_sav_magasin_user" model="res.groups">
        <field name="name">Accueil magasin</field>
    </record>

    <record id="group_sav_magasin_technician" model="res.groups">
        <field name="name">Technicien batterie</field>
        <field name="implied_ids" eval="[(4, ref('group_sav_magasin_user'))]"/>
    </record>

    <record id="group_sav_magasin_stock_purchase" model="res.groups">
        <field name="name">Stock &amp; Achat</field>
        <field name="implied_ids" eval="[(4, ref('group_sav_magasin_user'))]"/>
    </record>

    <record id="group_sav_magasin_manager" model="res.groups">
        <field name="name">Responsable magasin</field>
        <field name="implied_ids" eval="[(4, ref('group_sav_magasin_technician')), (4, ref('group_sav_magasin_stock_purchase'))]"/>
    </record>

    <record id="group_sav_magasin_admin" model="res.groups">
        <field name="name">Administrateur métier</field>
        <field name="implied_ids" eval="[(4, ref('group_sav_magasin_manager'))]"/>
    </record>
</odoo>

<odoo>
    <record id="view_sav_magasin_product_brand_list" model="ir.ui.view">
        <field name="name">sav.magasin.product.brand.list</field>
        <field name="model">sav.magasin.product.brand</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sav_magasin_product_brand_form" model="ir.ui.view">
        <field name="name">sav.magasin.product.brand.form</field>
        <field name="model">sav.magasin.product.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sav_magasin_product_brand" model="ir.actions.act_window">
        <field name="name">Marques</field>
        <field name="res_model">sav.magasin.product.brand</field>
        <field name="view_mode">list,form</field>
    </record>

